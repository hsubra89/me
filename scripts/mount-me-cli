#!/usr/bin/env bash
set -euo pipefail

command_name="mount-me-cli"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git -C "$script_dir" rev-parse --show-toplevel)"
cli_dir="$repo_root/go/cli"
bin_dir="${ME_DEV_BIN_DIR:-$HOME/.local/bin}"
launcher_name="${ME_DEV_LAUNCHER_NAME:-me}"
force=0
unmount=0
marker="# generated by scripts/mount-me-cli"

usage() {
  cat <<'USAGE'
Usage: scripts/mount-me-cli [--bin-dir DIR] [--name NAME] [--force] [--unmount]

Creates a local launcher for the Go `me` CLI dev build. The launcher runs
`go run ./cmd/me` from this checkout, so changes are picked up automatically.

Options:
  --bin-dir DIR  Directory for the launcher, default: ${ME_DEV_BIN_DIR:-$HOME/.local/bin}
  --name NAME    Launcher name, default: ${ME_DEV_LAUNCHER_NAME:-me}
  --force        Replace an existing file at the launcher path
  --unmount      Remove a launcher previously created by this script
  -h, --help     Show this help

Environment:
  ME_DEV_BIN_DIR        Default launcher directory
  ME_DEV_LAUNCHER_NAME  Default launcher name
USAGE
}

die() {
  echo "$command_name: $*" >&2
  exit 1
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --bin-dir)
      [ "$#" -ge 2 ] || die "--bin-dir requires a directory"
      bin_dir="$2"
      shift 2
      ;;
    --name)
      [ "$#" -ge 2 ] || die "--name requires a launcher name"
      launcher_name="$2"
      shift 2
      ;;
    --force)
      force=1
      shift
      ;;
    --unmount)
      unmount=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

[ -d "$cli_dir" ] || die "Go CLI directory not found: $cli_dir"
[ -f "$cli_dir/cmd/me/main.go" ] || die "Go CLI entrypoint not found: $cli_dir/cmd/me/main.go"
[ -n "$launcher_name" ] || die "--name cannot be empty"
case "$launcher_name" in
  */*) die "--name must be a file name, not a path" ;;
esac

launcher_path="$bin_dir/$launcher_name"

if [ "$unmount" -eq 1 ]; then
  if [ ! -e "$launcher_path" ]; then
    echo "$launcher_path is not mounted"
    exit 0
  fi
  if ! grep -Fq "$marker" "$launcher_path" 2>/dev/null; then
    die "refusing to remove $launcher_path because it was not created by this script"
  fi
  rm -f -- "$launcher_path"
  echo "Removed $launcher_path"
  exit 0
fi

mkdir -p -- "$bin_dir"

if [ -e "$launcher_path" ] && [ "$force" -ne 1 ]; then
  if ! grep -Fq "$marker" "$launcher_path" 2>/dev/null; then
    die "$launcher_path already exists; rerun with --force to replace it"
  fi
fi

printf -v quoted_cli_dir '%q' "$cli_dir"
tmp_path="$(mktemp "$bin_dir/.$launcher_name.tmp.XXXXXX")"
{
  printf '%s\n' '#!/usr/bin/env bash'
  printf '%s\n' 'set -euo pipefail'
  printf '%s\n' "$marker"
  printf 'cd -- %s\n' "$quoted_cli_dir"
  printf '%s\n' 'exec go run ./cmd/me "$@"'
} > "$tmp_path"
chmod 755 "$tmp_path"
mv -f -- "$tmp_path" "$launcher_path"

echo "Mounted $launcher_name at $launcher_path"
if ! command -v "$launcher_name" >/dev/null 2>&1; then
  echo "Add $bin_dir to PATH to run '$launcher_name' from anywhere."
elif [ "$(command -v "$launcher_name")" != "$launcher_path" ]; then
  echo "Note: PATH currently resolves '$launcher_name' to $(command -v "$launcher_name"), not $launcher_path."
fi
